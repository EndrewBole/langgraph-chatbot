# OpenAI
OPENAI_API_KEY=sk-...
MODEL_NAME=gpt-4o-mini
WHISPER_MODEL=whisper-1

# LangSmith (observability — optional)
LANGSMITH_TRACING=false
LANGCHAIN_API_KEY=lsv2_pt_...
LANGCHAIN_PROJECT=temporalis-chatbot

# PostgreSQL (conversation memory — Supabase connection string)
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# Supabase (RAG pgvector)
SUPABASE_URL=https://[ref].supabase.co
SUPABASE_SERVICE_KEY=sb_secret_...

# Evolution API (WhatsApp)
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_API_KEY=your-api-key
EVOLUTION_INSTANCE_NAME=your-instance

# Chatwoot (customer support + Instagram DM)
CHATWOOT_API_URL=http://chatwoot:3000
CHATWOOT_API_KEY=your-chatwoot-token
CHATWOOT_ACCOUNT_ID=1

# RAG
EMBEDDING_MODEL=text-embedding-3-small
RAG_SIMILARITY_THRESHOLD=0.65
RAG_TOP_K=10
RAG_RERANK_TOP_N=3
DATA_DIR=./data

# Human Handoff
STORE_OWNER_PHONE=5511999999999
HUMAN_RELEASE_COMMAND=#BOT#

# Catalog Auto-Reindex
CATALOG_REINDEX_ENABLED=true
CATALOG_REINDEX_INTERVAL_HOURS=24

# Docker Compose (used by docker-compose.yml)
POSTGRES_PASSWORD=changeme
CHATWOOT_SECRET_KEY_BASE=changeme
